<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>IMMONOVA | Success Story</title>

<style>
*{margin:0;padding:0;box-sizing:border-box}
html,body{width:100%;min-height:100%}
body{
  background:#f4ecdf;
  font-family:"Avenir Next","Helvetica Neue",Arial,sans-serif;
  color:#7f6430;
  overflow-x:hidden;
}
body::before{
  content:"";
  position:fixed;
  inset:0;
  z-index:-2;
  background:
    radial-gradient(circle at center,rgba(255,255,255,.72) 0%,rgba(255,255,255,.34) 38%,rgba(244,236,223,.06) 72%),
    #f4ecdf;
}
body::after{
  content:"";
  position:fixed;
  inset:0;
  z-index:-1;
  background:
    repeating-linear-gradient(60deg,transparent 0 86px,rgba(188,149,78,.23) 87px,transparent 90px),
    repeating-linear-gradient(-60deg,transparent 0 86px,rgba(188,149,78,.22) 87px,transparent 90px),
    repeating-linear-gradient(0deg,transparent 0 148px,rgba(188,149,78,.13) 149px,transparent 152px);
  background-size:230px 199px;
  opacity:.30;
}
.header{
  padding:34px 52px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  border-bottom:1px solid rgba(166,127,52,.10);
  background:rgba(244,236,223,.62);
  backdrop-filter:blur(14px);
  position:sticky;
  top:0;
  z-index:20;
}
.logo{
  font-size:24px;
  font-weight:300;
  letter-spacing:.35em;
  color:#a67f34;
  text-decoration:none;
}
.nav{
  display:flex;
  gap:30px;
  align-items:center;
  flex-wrap:wrap;
}
.nav a{
  text-decoration:none;
  color:#a67f34;
  font-size:11px;
  letter-spacing:.24em;
  text-transform:uppercase;
  padding:0;
  border:none;
  background:transparent;
  position:relative;
}
.nav a::after{
  content:"";
  position:absolute;
  left:0;
  right:0;
  bottom:-8px;
  height:1px;
  background:#a67f34;
  transform:scaleX(0);
  transform-origin:center;
  transition:transform .28s ease;
}
.nav a:hover::after{
  transform:scaleX(1);
}
.nav a:hover{
  background:transparent;
  color:#7f6430;
}
.container{
  max-width:1320px;
  margin:0 auto;
  padding:64px 42px 100px;
}
.hero{
  display:grid;
  grid-template-columns:1fr .9fr;
  gap:46px;
  align-items:center;
  margin-bottom:54px;
}
.kicker{
  font-size:11px;
  letter-spacing:.34em;
  text-transform:uppercase;
  color:#9a793c;
  margin-bottom:16px;
}
.title{
  font-size:clamp(42px,5vw,74px);
  font-weight:200;
  line-height:1.05;
  letter-spacing:.06em;
  color:#a67f34;
  text-transform:uppercase;
  margin-bottom:20px;
}
.subtitle{
  font-size:16px;
  line-height:1.85;
  color:#8f7643;
  max-width:820px;
}
.hero-media{
  min-height:440px;
  border:1px solid rgba(166,127,52,.18);
  background:rgba(255,255,255,.18);
  position:relative;
  overflow:hidden;
}
.hero-media img{
  width:100%;
  height:100%;
  min-height:440px;
  object-fit:cover;
  display:block;
}
.placeholder{
  min-height:440px;
  display:flex;
  align-items:center;
  justify-content:center;
  text-align:center;
  color:#a67f34;
  letter-spacing:.22em;
  text-transform:uppercase;
  line-height:1.8;
}
.marker{
  position:absolute;
  right:18px;
  bottom:18px;
  padding:15px 18px;
  border:1px solid rgba(241,210,122,.45);
  background:linear-gradient(135deg,rgba(255,252,244,.42),rgba(166,127,52,.16));
  backdrop-filter:blur(14px) saturate(150%);
  color:#fff0b1;
  text-transform:uppercase;
  text-shadow:0 1px 10px rgba(0,0,0,.28);
}
.marker small{display:block;font-size:8px;letter-spacing:.22em;color:#f1d27a}
.marker strong{display:block;margin-top:5px;font-size:16px;letter-spacing:.18em}
.meta-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:16px;
  margin-bottom:54px;
}
.meta-card{
  min-height:130px;
  padding:20px;
  border:1px solid rgba(166,127,52,.18);
  background:rgba(255,255,255,.22);
}
.meta-label{
  font-size:9px;
  letter-spacing:.22em;
  text-transform:uppercase;
  color:#a67f34;
  margin-bottom:18px;
}
.meta-value{
  font-size:18px;
  color:#735f36;
  line-height:1.4;
}
.section{
  margin-top:58px;
  border-top:1px solid rgba(166,127,52,.16);
  padding-top:34px;
}
.section-title{
  font-size:17px;
  font-weight:300;
  letter-spacing:.26em;
  text-transform:uppercase;
  color:#a67f34;
  margin-bottom:24px;
}
.story-text{
  max-width:920px;
  font-size:16px;
  line-height:1.9;
  color:#735f36;
}
.timeline{
  max-width:920px;
}
.timeline-item{
  display:grid;
  grid-template-columns:160px 1fr;
  gap:24px;
  padding:22px 0;
  border-bottom:1px solid rgba(166,127,52,.12);
}
.timeline-date{
  font-size:11px;
  letter-spacing:.18em;
  text-transform:uppercase;
  color:#9a793c;
}
.timeline-title{
  font-size:20px;
  color:#a67f34;
  font-weight:300;
  margin-bottom:8px;
}
.timeline-desc{
  font-size:14px;
  line-height:1.7;
  color:#735f36;
}
.events-grid,.gallery{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:22px;
}
.event-card,.gallery-item{
  border:1px solid rgba(166,127,52,.16);
  background:rgba(255,255,255,.20);
  overflow:hidden;
}
.event-card img,.gallery-item img{
  width:100%;
  height:220px;
  object-fit:cover;
  display:block;
  background:rgba(166,127,52,.08);
}
.event-body{padding:20px}
.event-type{
  font-size:9px;
  letter-spacing:.18em;
  text-transform:uppercase;
  color:#9a793c;
  margin-bottom:8px;
}
.event-title{
  font-size:19px;
  color:#a67f34;
  font-weight:300;
  line-height:1.35;
  margin-bottom:8px;
}
.event-desc{
  font-size:13px;
  line-height:1.7;
  color:#735f36;
}
.status{min-height:20px;margin-bottom:20px;font-size:13px}.error{color:#9c2f2f}.success{color:#4f7f45}
.empty{
  padding:34px;
  color:#8f7643;
  border:1px solid rgba(166,127,52,.16);
  background:rgba(255,255,255,.18);
  line-height:1.7;
}
@media(max-width:1050px){.hero{grid-template-columns:1fr}.meta-grid{grid-template-columns:1fr 1fr}.events-grid,.gallery{grid-template-columns:1fr 1fr}}
@media(max-width:720px){.header{padding:28px 24px;flex-direction:column;gap:18px}.nav{justify-content:center}.container{padding:44px 22px 78px}.meta-grid,.events-grid,.gallery{grid-template-columns:1fr}.timeline-item{grid-template-columns:1fr}.title{font-size:38px}}
</style>
</head>

<body>
<header class="header">
  <a href="index.html" class="logo">IMMONOVA</a>
  <nav class="nav">
    <a href="index.html">Home</a>
    <a href="opportunities.html">Opportunities</a>
    <a href="success-stories.html">Success Stories</a>
    <a href="events.html">Events</a>
    <a href="off-market.html">Off Market</a>
    <a href="contact.html">Contact</a>
  </nav>
</header>

<main class="container">
  <div id="status" class="status"></div>
  <div id="pageContent"><div class="empty">Loading Success Story...</div></div>
</main>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="js/config.js"></script>
<script>
const client = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
const params = new URLSearchParams(window.location.search);
const id = params.get("id");
const pageContent = document.getElementById("pageContent");
const statusBox = document.getElementById("status");

const eventLabels = {
  selling_party:"Selling Party",
  closing_party:"Closing Party",
  welcome_party:"Welcome Party",
  past_party:"Party avvenuto",
  upcoming_party:"Party in programma",
  investor_tour:"Investor Tour",
  site_visit:"Site Visit",
  private_dinner:"Private Dinner"
};

function esc(v){
  return String(v ?? "")
    .replaceAll("&","&amp;")
    .replaceAll("<","&lt;")
    .replaceAll(">","&gt;")
    .replaceAll('"',"&quot;")
    .replaceAll("'","&#039;");
}

function setStatus(message,type){
  statusBox.className = "status " + (type || "");
  statusBox.textContent = message || "";
}

function fmtDate(v){
  if(!v) return "";
  try{
    return new Date(v).toLocaleDateString("it-IT",{day:"2-digit",month:"long",year:"numeric"});
  }catch(e){
    return v;
  }
}

function normalizeGallery(value){
  if(!value)return [];
  if(Array.isArray(value))return value.filter(Boolean);
  try{
    const parsed=JSON.parse(value);
    return Array.isArray(parsed)?parsed.filter(Boolean):[];
  }catch(e){
    return [];
  }
}

function cover(item){
  return item.cover_image || normalizeGallery(item.gallery_images)[0] || "";
}

function eventsFor(item){
  return item.immonova_events || [];
}

function timelineFor(item){
  const timeline = item.opportunity_timeline || [];
  const events = eventsFor(item).map(function(e){
    return {
      created_at:e.event_date || e.created_at,
      timeline_type:e.event_type,
      title:eventLabels[e.event_type] || e.title || "Evento IMMONOVA",
      description:e.title || e.short_description || e.description || "",
      visibility:"public"
    };
  });

  const sold = item.sold_at ? [{
    created_at:item.sold_at,
    timeline_type:"sold",
    title:"Investment Completed",
    description:"Operazione conclusa e certificata come IMMONOVA Success Story.",
    visibility:"public"
  }] : [];

  return timeline.concat(events).concat(sold)
    .filter(x => (x.visibility || "public") === "public")
    .sort((a,b) => new Date(a.created_at || 0) - new Date(b.created_at || 0));
}

function heroMedia(item){
  const img = cover(item);
  if(!img){
    return '<div class="hero-media"><div class="placeholder">IMMONOVA<br>Verified Transaction</div><div class="marker"><small>Verified</small><strong>IMMONOVA</strong></div></div>';
  }
  return '<div class="hero-media"><img src="'+esc(img)+'" alt="'+esc(item.title || "Success Story")+'"><div class="marker"><small>Verified</small><strong>IMMONOVA</strong></div></div>';
}

function renderTimeline(item){
  const data = timelineFor(item);
  if(!data.length){
    return '<div class="empty">Timeline in aggiornamento.</div>';
  }

  return '<div class="timeline">' + data.map(function(t){
    return '<div class="timeline-item">'
      + '<div class="timeline-date">'+esc(fmtDate(t.created_at))+'</div>'
      + '<div><div class="timeline-title">'+esc(t.title || t.timeline_type || "Step")+'</div>'
      + '<div class="timeline-desc">'+esc(t.description || "")+'</div></div>'
      + '</div>';
  }).join("") + '</div>';
}

function renderEvents(item){
  const evs = eventsFor(item);
  if(!evs.length){
    return '<div class="empty">Nessun evento pubblico collegato.</div>';
  }

  return '<div class="events-grid">' + evs.map(function(e){
    const img = e.cover_image ? '<img src="'+esc(e.cover_image)+'" alt="'+esc(e.title || "Evento")+'">' : '';
    return '<article class="event-card">'
      + img
      + '<div class="event-body">'
      + '<div class="event-type">'+esc(eventLabels[e.event_type] || e.event_type || "Evento")+'</div>'
      + '<div class="event-title">'+esc(e.title || "Evento IMMONOVA")+'</div>'
      + '<div class="event-desc">'+esc([fmtDate(e.event_date), e.location, e.venue].filter(Boolean).join(" · "))+'</div>'
      + '</div></article>';
  }).join("") + '</div>';
}

function renderGallery(item){
  const gallery = normalizeGallery(item.gallery_images);
  if(!gallery.length){
    return '<div class="empty">Gallery in aggiornamento.</div>';
  }

  return '<div class="gallery">' + gallery.map(function(url){
    return '<div class="gallery-item"><img src="'+esc(url)+'" alt="IMMONOVA Success Story"></div>';
  }).join("") + '</div>';
}

function render(item){
  const year = item.sold_at ? new Date(item.sold_at).getFullYear() : new Date(item.created_at || Date.now()).getFullYear();
  const place = [item.location,item.category].filter(Boolean).join(" · ");
  const intro = item.full_description || item.short_description || "Operazione off-market IMMONOVA conclusa con successo e trasformata in una Success Story verificata. I dati economici e le parti coinvolte restano riservati.";

  pageContent.innerHTML =
    '<section class="hero">'
    + '<div>'
    + '<div class="kicker">IMMONOVA Verified Transaction</div>'
    + '<h1 class="title">'+esc(item.title || "Success Story")+'</h1>'
    + '<p class="subtitle">'+esc(intro)+'</p>'
    + '</div>'
    + heroMedia(item)
    + '</section>'

    + '<section class="meta-grid">'
    + '<div class="meta-card"><div class="meta-label">Status</div><div class="meta-value">Investment Completed</div></div>'
    + '<div class="meta-card"><div class="meta-label">Year</div><div class="meta-value">'+esc(year)+'</div></div>'
    + '<div class="meta-card"><div class="meta-label">Location</div><div class="meta-value">'+esc(item.location || "Riservata")+'</div></div>'
    + '<div class="meta-card"><div class="meta-label">Segment</div><div class="meta-value">'+esc(item.category || item.investment_type || "Private Investment")+'</div></div>'
    + '</section>'

    + '<section class="section"><h2 class="section-title">Investment Story</h2><div class="story-text">'+esc(intro).replaceAll("\\n","<br>")+'</div></section>'
    + '<section class="section"><h2 class="section-title">Timeline</h2>'+renderTimeline(item)+'</section>'
    + '<section class="section"><h2 class="section-title">Linked Events</h2>'+renderEvents(item)+'</section>'
    + '<section class="section"><h2 class="section-title">Gallery</h2>'+renderGallery(item)+'</section>';
}

async function loadStory(){
  if(!id){
    pageContent.innerHTML = '<div class="empty">Success Story non trovata.</div>';
    return;
  }

  try{
    const { data, error } = await client
      .from("opportunities")
      .select("*, immonova_events(*), opportunity_timeline(*)")
      .eq("id", id)
      .eq("commercial_status", "sold")
      .single();

    if(error) throw error;

    render(data);
  }catch(error){
    console.error(error);
    setStatus("Errore caricamento Success Story: " + (error.message || error), "error");
    pageContent.innerHTML = '<div class="empty">Success Story temporaneamente non disponibile.</div>';
  }
}

loadStory();
</script>
</body>
</html>
